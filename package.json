{
  "name": "sls-sql-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Natural-language SQL generator for Alibaba Cloud SLS logs.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/app.ts",
    "dev:client": "vite --host 0.0.0.0 client",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build client",
    "start": "node server/dist/app.js",
    "test": "npm run build:server && node server/test/generator.test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "cors": "^2.8.5",
    "element-plus": "^2.9.10",
    "express": "^4.21.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vue-tsc": "^2.2.10"
  }
}
